{
  "name": "nizaamomer/laravel-fib",
  "description": "Modern Laravel SDK for First Iraqi Bank (FIB): online payments and payouts, with typed DTOs, multi-account support, and webhook-safe status verification.",
  "keywords": [
    "laravel",
    "fib",
    "first-iraqi-bank",
    "payment",
    "payout",
    "sdk",
    "iraq"
  ],
  "homepage": "https://github.com/nizaamomer/laravel-fib",
  "license": "MIT",
  "authors": [
    {
      "name": "Nizaam Omer",
      "email": "nizaamomer@gmail.com",
      "homepage": "https://nizaamomer.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/console": "^11.0 || ^12.0 || ^13.0",
    "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
    "illuminate/database": "^11.0 || ^12.0 || ^13.0",
    "illuminate/http": "^11.0 || ^12.0 || ^13.0",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0",
    "spatie/laravel-package-tools": "^1.16"
  },
  "require-dev": {
    "larastan/larastan": "^2.9 || ^3.0",
    "laravel/pint": "^1.17",
    "orchestra/testbench": "^9.0 || ^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Nizaamomer\\LaravelFib\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nizaamomer\\LaravelFib\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage",
    "analyse": "vendor/bin/phpstan analyse",
    "format": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nizaamomer\\LaravelFib\\FibServiceProvider"
      ],
      "aliases": {
        "FibPayment": "Nizaamomer\\LaravelFib\\Facades\\FibPayment",
        "FibPayout": "Nizaamomer\\LaravelFib\\Facades\\FibPayout"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
